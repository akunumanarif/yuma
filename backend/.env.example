# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
FAL_KEY=...

# Storage
TEMP_DIR=./temp/jobs
MAX_JOB_AGE_HOURS=24

# Server
CORS_ORIGINS=http://localhost:3000
PORT=8000

# Pipeline tuning
DEFAULT_NUM_STAGES=6
IMG2IMG_STRENGTH_DEFAULT=0.70
CLIP_DURATION_SECONDS=5
KLING_ASPECT_RATIO=16:9
FLUX_IMAGE_SIZE=landscape_16_9

# Timeouts / Retries
FAL_POLL_TIMEOUT_SECONDS=600
FAL_MAX_RETRIES=3
